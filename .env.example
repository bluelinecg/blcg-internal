# ============================================================
# BLCG Internal — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# .env.local is gitignored and must NEVER be committed.
# All variables must also be added to Vercel before deploying.
# ============================================================

# Clerk Authentication
# Get these from: https://dashboard.clerk.com > Your App > API Keys
#
# Public key — safe to expose to the browser, required on client
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
#
# Secret key — server-side only, NEVER expose to the client or commit
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk redirect paths — tells Clerk where your custom auth pages live
# and where to redirect after a successful sign-in or sign-up event.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API
#
# Project URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#
# Anon (public) key — safe to expose to the browser, subject to RLS policies
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
#
# Service role key — server-side only, bypasses RLS, NEVER expose to the client or commit
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
