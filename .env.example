# ============================================================
# BLCG Internal — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# .env.local is gitignored and must NEVER be committed.
# All variables must also be added to Vercel before deploying.
# ============================================================

# Clerk Authentication
# Get these from: https://dashboard.clerk.com > Your App > API Keys
#
# Public key — safe to expose to the browser, required on client
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
#
# Secret key — server-side only, NEVER expose to the client or commit
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk redirect paths — tells Clerk where your custom auth pages live
# and where to redirect after a successful sign-in or sign-up event.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API
#
# Project URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#
# Anon (public) key — safe to expose to the browser, subject to RLS policies
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
#
# Service role key — server-side only, bypasses RLS, NEVER expose to the client or commit
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Sentry Error Monitoring
# Get DSN from: https://sentry.io > Your Project > Settings > Client Keys (DSN)
#
# Public DSN — safe to expose to the browser (it only receives errors, never returns data).
# The app runs normally without this — Sentry is disabled when absent.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
#
# Auth token — used at BUILD TIME ONLY to upload source maps to Sentry.
# Generate from: https://sentry.io > Settings > Auth Tokens
# Add to Vercel environment variables (not needed locally unless testing builds).
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
#
# Sentry org and project slugs — required for source map upload.
# Find at: https://sentry.io > Settings > General > Organization Slug
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# Internal API Key
# Used by Claude Code agents to interact with the kanban board without a Clerk session.
# Generate any strong random string (e.g. openssl rand -hex 32).
# Keep this secret — anyone with this key can read and write all tasks.
INTERNAL_API_KEY=your_internal_api_key_here

# Gmail API
# Get Client ID and Secret from: https://console.cloud.google.com > Credentials > OAuth 2.0 Client IDs
# Refresh tokens are generated once per account via /api/auth/gmail/[account] (see TASKS.md)
#
GMAIL_CLIENT_ID=your_google_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret_here
#
# Redirect URI — only needed for the one-time OAuth setup flow; defaults to localhost if not set
# GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
#
# Refresh tokens — generated once per account via the OAuth consent flow
GMAIL_REFRESH_TOKEN_RYAN=your_refresh_token_for_ryan_here
GMAIL_REFRESH_TOKEN_GMAIL=your_refresh_token_for_bluelinecgllc_here
